  "files": [
    "dist",
    "!dist/**/*.map",
    "!dist/node_modules",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "dev:check": "node scripts/dev-check.mjs",
    "build": "npm run generate:exports && vite build && vue-tsc --emitDeclarationOnly && npm run build:css && npm run check:package-size && node scripts/smoke-test-peer-free.mjs",
    "build:css": "cd src && find . -name '*.css' -exec sh -c 'mkdir -p \"../dist/$(dirname \"$1\")\" && cp \"$1\" \"../dist/$1\"' _ {} \\;",
    "generate:exports": "node scripts/generate-package-exports.mjs",
    "check:exports-drift": "node scripts/generate-package-exports.mjs --check",
    "check:package-size": "node scripts/check-package-size.mjs",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --fix",
    "format": "prettier --write src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "publish:patch": "./scripts/publish.sh patch",
    "publish:minor": "./scripts/publish.sh minor",
    "publish:major": "./scripts/publish.sh major"
  },
  "peerDependencies": {
    "@vueuse/core": "^14.0.0",
    "luxon": "^3.0.0",
    "vue": "^3.5.0",
    "yaml": "^2.4.5"
  },
