# DX-961/DX-986 — board-rooted inject trees + worktrees are regenerable client
# runtime (CP3) and must NEVER be tracked. Blanket-ignore the whole subtree, as
# danxbot's own .danxbot/.gitignore does. Embedded worktree gitlinks here would
# also break clones.
boards/*/workspaces/
boards/*/worktrees/
boards/*/lists.yaml

# Live poller runtime state — rewritten every tick (DX-324 cron tick, DX-558
# sync state, strike/meta in settings.json). Never track.
cron-state.json
boards/*/cron-state.json
settings.json
boards/*/settings.json
sync-root-state.json
