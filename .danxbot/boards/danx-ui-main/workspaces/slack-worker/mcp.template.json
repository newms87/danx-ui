{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["tsx", "mcp-servers/playwright/src/index.ts"],
      "env": {
        "PLAYWRIGHT_URL": "${DANXBOT_PLAYWRIGHT_URL}",
        "DANX_RUNTIME": "${DANX_RUNTIME}"
      }
    },
    "danx_dashboard": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@thehammer/danx-dashboard-mcp"],
      "env": {
        "DANXBOT_DASHBOARD_URL": "${DANXBOT_DASHBOARD_URL}",
        "DANXBOT_DISPATCH_TOKEN": "${DANXBOT_DISPATCH_TOKEN}",
        "DANX_REPO_NAME": "${DANX_REPO_NAME}",
        "DANXBOT_BOARD_NAME": "${DANXBOT_BOARD_NAME}"
      }
    }
  }
}
